config NXP_UART_WIFI_BRIDGE
	bool "Support UART_WIFI_BRIDGE"
	default y

config NXP_MONOLITHIC_WIFI
	bool "Support WIFI monolithic"

config SUPPORT_IEEE802154
	bool "Support IEEE 802154"
	imply NXP_MONOLITHIC_NBU

config SUPPORT_BLE
	bool "Support bluetooth low energy"
	default y
	imply NXP_MONOLITHIC_NBU

config SUPPORT_WIFI
	bool "Support WiFi"
	default y
	imply NXP_MONOLITHIC_WIFI

config NXP_COMBO_FW_LOAD
	bool "Support FW load for both Wi-Fi + BT"
	default n

config BT_UART_BAUDRATE
	int "BT UART Baudrate"
	default 115200

config SUPPORT_BT_UART
	bool "Support BT UART Interface"
	default n
	select NXP_COMBO_FW_LOAD

source "Kconfig.zephyr"