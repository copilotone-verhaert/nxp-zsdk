&m2_hci_bt_uart {
	/delete-property/ pinctrl-0;
	/delete-property/ pinctrl-1;
	/delete-property/ pinctrl-2;
	/delete-property/ pinctrl-names;
	pinctrl-0 = <&pinmux_lpuart3_flow_control>;
	pinctrl-1 = <&pinmux_lpuart3_sleep>;
	pinctrl-names = "default", "sleep";
	current-speed = <3000000>;
	status = "okay";
};

&gpio1 {
	status = "okay";

	wl-rst-hog {
		/* Mark this node as GPIO hog for automatic initialization */
		gpio-hog;
		/* Specify GPIO1_IO19, active-high polarity */
		gpios = <19 GPIO_ACTIVE_HIGH>;
		/* Set as OUTPUT mode with initial LOW state (reset asserted) */
		output-low;
		/* Human-readable name for debug/documentation purposes */
		line-name = "WL_RST";
	};

	sdio-rst-hog {
		gpio-hog;
		gpios = <24 GPIO_ACTIVE_HIGH>;
		output-low;
		line-name = "SDIO_RST";
	};
};
&gpio2 {
	status = "okay";

	zb-spi-int-hog {
		gpio-hog;
		gpios = <4 GPIO_ACTIVE_HIGH>;
		input;
		line-name = "ZB_SPI_INT";
	};
};

/* LPSPI4 ZigBee RCP */
&lpspi4 {
	status = "okay";
	pinctrl-0 = <&pinmux_lpspi4>;
	pinctrl-names = "default";

	clock-frequency = <2000000>;
	/* Delay in nanoseconds from the chip select assert to the first clock edge */
	pcs-sck-delay = <147>;
	/* Delay in nanoseconds from the last clock edge to the chip select deassert */
	sck-pcs-delay = <147>;
	/* Delay in nanoseconds between last SCK edge of a transfer word and the first SCK edge of the next transfer word */
	transfer-delay = <147>;

	zigbee_rcp: spi-device@0 {
		compatible = "nxp,imx-lpspi-device";
		reg = <0>;  /* Chip Select 0 */
		spi-max-frequency = <2000000>;
	};
};

&lpi2c1 {
	status = "okay";
	pinctrl-0 = <&pinmux_lpi2c1>;
	pinctrl-names = "default";
	clock-frequency = <100000>;

	io_expander: pca9534@20 {
		compatible = "nxp,pca95xx";
		reg = <0x20>;
		gpio-controller;
		#gpio-cells = <2>;
	};
};

&pinctrl {
	pinmux_lpspi4: pinmux_lpspi4 {
		group0 {
			pinmux =
				<&iomuxc_gpio_b0_00_lpspi4_pcs0>,   // GPIO_B0_00 → LPSPI4_PCS0
				<&iomuxc_gpio_b0_01_lpspi4_sdi>,   // GPIO_B0_01 → LPSPI4_SDI
				<&iomuxc_gpio_b0_02_lpspi4_sdo>,   // GPIO_B0_02 → LPSPI4_SDO
				<&iomuxc_gpio_b0_03_lpspi4_sck>;   // GPIO_B0_03 → LPSPI4_SCK
			/* Enable pull-up resistor (PUE=1) */
			bias-pull-up;
			/* Pull-up resistor: 100kΩ (PUS=10) */
			bias-pull-up-value = "100k";
			/* Drive strength: 32Ω@3.3V, 43Ω@1.8V (DSE=110) */
			drive-strength = "r0-6";
			/* Slew rate: slow (SRE=0) */
			slew-rate = "slow";
			/* Pin speed: medium, up to 100MHz (SPEED=01) */
			nxp,speed = "100-mhz";
		};
	};

	pinmux_lpi2c1: pinmux_lpi2c1 {
		group0 {
			pinmux =
				<&iomuxc_gpio_ad_b1_00_lpi2c1_scl>,
				<&iomuxc_gpio_ad_b1_01_lpi2c1_sda>;
			bias-pull-up;
			bias-pull-up-value = "100k";
			drive-strength = "r0-6";
			slew-rate = "slow";
			nxp,speed = "100-mhz";
		};
	};

	pinmux_wifi_sdio_rst: pinmux_wifi_sdio_rst {
		group0 {
			pinmux = <&iomuxc_gpio_ad_b1_03_gpio1_io19>,
					 <&iomuxc_gpio_ad_b1_08_gpio1_io24>;
			bias-pull-up;
			bias-pull-up-value = "100k";
			drive-strength = "r0-6";
			slew-rate = "slow";
			nxp,speed = "100-mhz";
		};
	};

	pinmux_spi_int: pinmux_spi_int {
		group0 {
			pinmux = <&iomuxc_gpio_b0_04_gpio2_io04>;
			bias-pull-up;
			bias-pull-up-value = "100k";
			drive-strength = "r0-6";
			slew-rate = "slow";
			input-enable;
			nxp,speed = "100-mhz";
		};
	};

	pinmux_usdhc1: pinmux_usdhc1 {
		group0 {
			pinmux =
				<&iomuxc_gpio_b1_14_usdhc1_vselect>,
				<&iomuxc_gpio_sd_b0_00_usdhc1_cmd>,
				<&iomuxc_gpio_sd_b0_02_usdhc1_data0>,
				<&iomuxc_gpio_sd_b0_03_usdhc1_data1>,
				<&iomuxc_gpio_sd_b0_04_usdhc1_data2>,
				<&iomuxc_gpio_sd_b0_05_usdhc1_data3>;
			bias-pull-up;
			bias-pull-up-value = "47k";
			drive-strength = "r0-6";
			slew-rate = "slow";
			nxp,speed = "200-mhz";
		};

		group1 {
			pinmux = <&iomuxc_gpio_sd_b0_01_usdhc1_clk>;
			drive-strength = "r0-6";
			slew-rate = "fast";
			nxp,speed = "200-mhz";
		};
	};

	pinmux_usdhc1_dat3_nopull: pinmux_usdhc1_dat3_nopull {
		group0 {
			pinmux = <&iomuxc_gpio_sd_b0_01_usdhc1_clk>;
			bias-disable;
			drive-strength = "r0";
			input-schmitt-enable;
			slew-rate = "fast";
			nxp,speed = "100-mhz";
		};
		group1 {
			pinmux = <&iomuxc_gpio_b1_12_gpio2_io28>,
				<&iomuxc_gpio_sd_b0_00_usdhc1_cmd>,
				<&iomuxc_gpio_sd_b0_02_usdhc1_data0>,
				<&iomuxc_gpio_sd_b0_03_usdhc1_data1>,
				<&iomuxc_gpio_sd_b0_04_usdhc1_data2>;
			drive-strength = "r0";
			input-schmitt-enable;
			bias-pull-up;
			bias-pull-up-value = "47k";
			slew-rate = "fast";
			nxp,speed = "100-mhz";
		};
		group2 {
			pinmux = <&iomuxc_gpio_sd_b0_05_usdhc1_data3>;
			drive-strength = "r0";
			input-schmitt-enable;
			bias-disable;
			slew-rate = "fast";
			nxp,speed = "100-mhz";
		};
	};
};

